# ── Groq LLM Configuration ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── JWT Authentication Secret ─────────────────────────────────────────────────
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=generate_a_secure_random_key_here

# ── Database Connection ───────────────────────────────────────────────────────
# Option A: Single Connection URL (Recommended for PlanetScale / Railway Managed MySQL)
# Note: For PlanetScale, SSL is required. You can append the SSL CA certs path.
# On Railway's Debian-based Docker containers, CA certificates are located at:
# /etc/ssl/certs/ca-certificates.crt
MYSQL_URL=mysql+pymysql://username:password@host.planetscale.com/database_name?ssl_ca=/etc/ssl/certs/ca-certificates.crt

# Option B: Individual Database Parameters (Alternative)
# The application will auto-generate the MYSQL_URL if these are defined:
# MYSQL_HOST=host.planetscale.com
# MYSQL_PORT=3306
# MYSQL_USER=username
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=database_name

# ── College Config (SaaS Customization) ───────────────────────────────────────
COLLEGE_CLIENT_ID=4a78c1ab-98db-4e12-b5fb-df98a9643d92

